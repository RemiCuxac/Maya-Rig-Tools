        -imageOverlayLabel "Match" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "move_M.png" 
        -image1 "move_M.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "MatchTransform -position -rotation" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1

    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Create locator from gizmo" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Create aligned locator " 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Loc" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "locator.svg" 
        -image1 "locator.svg" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\n\ndef create_loc_from_gizmo(pObjList: list):\n    prevObjName = \"\"\n    if not pObjList:\n        obj = cmds.spaceLocator(name = \"locator_01\")\n        return\n    for obj in pObjList:\n        objName = obj.split('|')[-1].split('.')[0]\n        mat = cmds.xform(obj, q=True, ws=True, m=True)\n        pos = cmds.manipMoveContext(\"Move\", q=True, p=True)\n        if objName == prevObjName:\n            continue\n        prevObjName = objName\n        obj = cmds.spaceLocator(name=f\"locator_{objName}\")\n        cmds.setToolTo(\"moveSuperContext\")\n        cmds.xform(obj, ws=True, m=mat)\n        cmds.xform(obj, ws=True, translation=pos)\n\n\nsel = cmds.ls(sl=1)\ncreate_loc_from_gizmo(sel)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Create joint" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 

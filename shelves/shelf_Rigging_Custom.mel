        -preventOverride 0
        -annotation "Extract joint" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Extract joint" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Extract" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "kinDisconnect.png" 
        -image1 "kinDisconnect.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\n\ndef extract_joint(pObjList: list):\n    for obj in pObjList:\n        objName = obj.split(\"|\")[-1] if \"|\" in obj else obj\n        newObj = cmds.duplicate(obj, parentOnly=True)[0]\n        parent = cmds.listRelatives(obj, parent=True)\n        if parent:\n            cmds.parent(newObj, world=True)\n        radius = cmds.getAttr(f\"{obj}.radius\")\n        cmds.setAttr(f\"{newObj}.radius\", radius + 1)\n        cmds.rename(newObj, f\"{objName}_to_rename\")\n\n\nsel = cmds.ls(sl=1, type=\"joint\")\nextract_joint(sel) if sel else cmds.warning(\"Please select a joint from your skeleton\", n=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3

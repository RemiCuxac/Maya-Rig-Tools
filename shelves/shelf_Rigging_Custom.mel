        -annotation "Select the root bone and execute; it will create a range of motion for all children." 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Range of Motion" 
        -labelOffset 0
        -rotation 0

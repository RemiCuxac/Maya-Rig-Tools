        -command "from maya import cmds\n\n\ndef color_obj(pObjList: list, pColorIndex: int):\n    for obj in pObjList:\n        objType = cmds.objectType(obj)\n        if objType == \"joint\":\n            cmds.setAttr(obj + \".overrideEnabled\", 1)\n            cmds.setAttr(obj + \".overrideColor\", pColorIndex)\n        else:\n            objShape = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            for shape in objShape:\n                cmds.setAttr(shape + \".overrideEnabled\", 1)\n                cmds.setAttr(shape + \".overrideColor\", pColorIndex)\n\n\nsel = cmds.ls(sl=1)\ncolor_obj(sel, 13) if sel else cmds.error(\"Please select a nurbsCurve or a joint.\", n=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1

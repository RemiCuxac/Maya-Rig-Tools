    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Create a correctly positioned group for each item in the selection" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Group Align" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Group" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "group.png" 
        -image1 "group.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\n\ndef group(pObjList: list):\n    if not pObjList:\n        cmds.group(n = \"grp_01\", empty=True)\n        return\n    for obj in pObjList:\n        objName = obj.split(\"|\")[-1]\n        parent = cmds.listRelatives(obj, parent=True, fullPath=True)\n        group = cmds.group(empty=True)\n        cmds.matchTransform(group, obj)\n        cmds.parent(obj, group)\n        if parent:\n            cmds.parent(group, parent)\n        cmds.rename(group, f\"grp_{objName}\")\n\n\nsel = cmds.ls(sl=1, long=True)\nsel.sort(key=lambda x:x.count(\"|\"), reverse=True)\ngroup(sel)\n\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Transfer transforms of current selection to his parent transform, then reset transforms of selection." 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Transfer Transform to Parents" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Reset Parent" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "group.png" 
        -image1 "group.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\n\ndef transfer_transforms_to_parent(pObjList: list):\n    for obj in pObjList:\n        parent = cmds.listRelatives(obj, parent=True)\n        if parent:\n            if cmds.objectType(parent) == \"transform\" and len(cmds.listRelatives(parent, shapes=True) or []) == 0:\n                cmds.matchTransform(parent, obj)\n                cmds.matchTransform(obj, parent)\n            \nsel = cmds.ls(sl=True, long=True, type=\"transform\")\ntransfer_transforms_to_parent(sel) if sel else cmds.error(\"Please select an object\", n=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Transfer transforms to OffsetParentMatrix attribute.\nThis will set transforms to 0 and helps to be free from group parents." 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Transfer transforms to offsetParentMatrix" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Offset Parent Matrix" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "decomposeMatrix.svg" 
        -image1 "decomposeMatrix.svg" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.api.OpenMaya as om\nimport maya.cmds as cmds\n\nTRANSFORM_NODETYPES = [\"transform\", \"joint\"]\n\n\ndef has_non_default_locked_attributes(pNode:str):\n    for attribute in [\"translate\", \"rotate\", \"scale\", \"jointOrient\"]:\n        default_value = 1 if attribute == \"scale\" else 0\n        for axis in \"XYZ\":\n            if cmds.attributeQuery(attribute + axis, node=pNode, exists=True):\n                attribute_name = f\"{pNode}.{attribute}{axis}\"\n                current_value = cmds.getAttr(attribute_name)\n                if cmds.getAttr(attribute_name, lock=True) and current_value != default_value:\n                    return True\n\n\ndef reset_transforms(pNode:str):\n    for attribute in [\"translate\", \"rotate\", \"scale\", \"jointOrient\"]:\n        value = 1 if attribute == \"scale\" else 0\n        for axis in \"XYZ\":\n            if cmds.attributeQuery(attribute + axis, node=pNode, exists=True):\n                attribute_name = f\"{pNode}.{attribute}{axis}\"\n                if not cmds.getAttr(attribute_name, lock=True):\n                    cmds.setAttr(attribute_name, value)\n\n\ndef bake_transform_to_offset_parent_matrix(pObjList: list):\n    for node in pObjList:\n        if cmds.nodeType(node) not in TRANSFORM_NODETYPES:\n            raise ValueError(\"Node {} is not a transform node\".format(node))\n\n        if has_non_default_locked_attributes(node):\n            raise RuntimeError(\"Node {} has at least one non default locked attribute(s)\".format(node))\n\n        local_matrix = om.MMatrix(cmds.xform(node, q=True, m=True, ws=False))\n        offset_parent_matrix = om.MMatrix(cmds.getAttr(node + \".offsetParentMatrix\"))\n        baked_matrix = local_matrix * offset_parent_matrix\n        cmds.setAttr(node + \".offsetParentMatrix\", baked_matrix, type=\"matrix\")\n    \n        reset_transforms(node)\n\n\nsel = cmds.ls(sl=True)\nbake_transform_to_offset_parent_matrix(sel) if sel else cmds.error(\"Please select an object\", n=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Freeze Transformations" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Freeze Transformations" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0.255 0.255 0.255 0.5 
        -image "FreezeTransform.png" 
        -image1 "FreezeTransform.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.api.OpenMaya as om\nfrom maya import cmds\n\n\ndef freeze_transform(pObjList: list):\n    for obj in pObjList:\n        if cmds.objectType(obj) == \"joint\":\n            # rotation\n            mat = cmds.xform(obj, q=True, m=True)\n            m = om.MMatrix(mat)\n            mt = om.MTransformationMatrix(m)\n            rot = mt.rotation()\n            rotRad = (rot.x, rot.y, rot.z)\n            rotDeg = [om.MAngle(angle).asDegrees() for angle in rotRad]\n            cmds.setAttr(f\"{obj}.rotate\", 0, 0, 0)\n            cmds.setAttr(f\"{obj}.jointOrient\", *rotDeg)\n            \n            # scale\n            skin = list(set(cmds.listConnections(obj, d=True, s=False, type=\"skinCluster\")))\n            if skin and cmds.getAttr(f\"{obj}.scale\")!=[(1.0, 1.0, 1.0)]:\n                cmds.warning(f\"Bind Pose has been modified since the scale of {obj} has changed. Please reset skin Bind Pose\")\n            listChildren = {}\n            for child in cmds.listRelatives(obj, fullPath=True, children=True) or []:\n                mat = cmds.xform(child, q=True, m=True, ws=True)\n                listChildren[child] = mat\n            cmds.setAttr(f\"{obj}.scale\", 1,1,1)\n            for child in listChildren:\n                cmds.xform(child, m=listChildren[child], ws=True)            \n        else:\n            cmds.makeIdentity(obj, apply=True, t=True, r=True, s=True, n=False, pn=True)\n\n\nsel = cmds.ls(sl=1)\nfreeze_transform(sel) if sel else cmds.error(\"Please select an object\", n=True)\n" 
        -sourceType "python" 
        -doubleClickCommand "FreezeTransformationsOptions" 
        -commandRepeatable 1
        -flat 1
    ;
    separator
        -enable 1

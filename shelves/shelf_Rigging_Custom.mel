        -command "from maya import cmds\n\n\ndef uncolor_obj(pObjList: list):\n    for obj in pObjList:\n        objType = cmds.objectType(obj)\n        if objType == \"joint\":\n            cmds.setAttr(obj + \".overrideEnabled\", 0)\n        else:\n            objShape = cmds.listRelatives(obj, fullPath=True) or []\n            for shape in objShape:\n                cmds.setAttr(shape + \".overrideEnabled\", 0)\n\n\nsel = cmds.ls(sl=1)\nuncolor_obj(sel) if sel else cmds.error(\"Please select a nurbsCurve or a joint.\", n=True)\n\n" 

        -annotation "Match the transforms of selected objects to the last-selected object. (Native way)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Match Transform" 
        -labelOffset 0
        -rotation 0
